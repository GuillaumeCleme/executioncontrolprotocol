          },
          {
            "kind": "answerContains",
            "text": "error"
          }
        ],
        "judge": {
          "enabled": true,
          "goal": "Explains echo failure",
          "rubric": "Mentions echo step and describes the error from run context",
          "requireApproved": true
        }
