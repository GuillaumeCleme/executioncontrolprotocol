      "title": "Label change",
      "harness": "workflow-authoring",
      "model": "default",
      "baselineWorkflow": "workflows/echo-workflow.json",
      "input": {
        "request": "Change the echo step label to Patched Echo."
      },
      "assertions": {
        "deterministic": [
          {
            "kind": "invokeSuccess"
          },
          {
            "kind": "artifactSchema",
            "value": "@ecp.workflow"
          },
          {
            "kind": "validationValid"
          },
          {
            "kind": "stepLabel",
            "stepId": "echo",
            "value": "Patched Echo"
          }
        ],
        "judge": {
          "enabled": false
        }
