{
  "schema": "@executioncontrolprotocol.workflow",
  "version": "1.0",
  "workflow": {
    "id": "echo-validate",
    "label": "Echo validate reorder"
  },
  "steps": [
    {
      "type": "step",
      "id": "echo",
      "label": "Echo",
      "uses": "@executioncontrolprotocol/demo.echo",
      "input": { "value": "before-validate" },
      "as": "echo"
    },
    {
      "type": "step",
      "id": "validate",
      "label": "Validate",
      "uses": "@executioncontrolprotocol/demo.validate",
      "input": { "payload": { "ok": true } },
      "as": "validated"
    }
  ]
}
