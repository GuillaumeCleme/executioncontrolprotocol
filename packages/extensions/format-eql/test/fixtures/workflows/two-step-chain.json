{
  "schema": "@ecp.workflow",
  "version": "1.0",
  "workflow": {
    "id": "two-step-chain",
    "label": "Two step chain"
  },
  "steps": [
    {
      "type": "step",
      "id": "echo",
      "label": "Echo",
      "uses": "@executioncontextprotocol/demo.echo",
      "input": { "value": "seed" },
      "as": "echo"
    },
    {
      "type": "step",
      "id": "summarize",
      "label": "Summarize",
      "uses": "@executioncontextprotocol/demo.summarize",
      "input": { "payload": { "$ref": "state.echo.output" } },
      "as": "summary"
    }
  ]
}
