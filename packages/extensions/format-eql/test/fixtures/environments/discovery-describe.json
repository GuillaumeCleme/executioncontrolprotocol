{
  "schema": "@ecp.environment.describe",
  "version": "1.0",
  "environment": {
    "id": "disc",
    "label": "Discovery"
  },
  "runtime": {
    "id": "@executioncontextprotocol/in-memory",
    "features": {
      "loops": true
    }
  },
  "extensions": [
    {
      "id": "@executioncontextprotocol/test",
      "order": 0,
      "capabilities": ["@executioncontextprotocol/test.echo"]
    }
  ],
  "capabilities": [
    {
      "id": "@executioncontextprotocol/test.echo",
      "label": "Echo",
      "extension": "@executioncontextprotocol/test",
      "inputSchema": {
        "value": "string!"
      },
      "outputSchema": {
        "output": "object"
      }
    },
    {
      "id": "@executioncontextprotocol/memory.search",
      "label": "Search Memory",
      "extension": "@executioncontextprotocol/memory",
      "inputSchema": {
        "query": "string!",
        "since": "string"
      },
      "outputSchema": {
        "results": "array"
      }
    }
  ],
  "policies": [
    {
      "id": "@executioncontextprotocol/budget",
      "label": "Budget Guardrails",
      "summary": "Spend limits"
    }
  ]
}
