{
  "name": "@ecp/workspace",
  "version": "1.0.0",
  "description": "Execution Control Protocol (ECP) — TypeScript fluent API for workflow authoring and execution",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/types",
    "packages/core",
    "packages/mcp",
    "packages/cli",
    "packages/policies",
    "packages/evals",
    "packages/harnesses/*",
    "packages/extensions/*",
    "packages/runtimes/*",
    "apps/*"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "tsc -b tsconfig.build.json",
    "lint": "eslint . && markdownlint-cli2",
    "lint:ts": "eslint .",
    "lint:md": "markdownlint-cli2",
    "test": "npm run build && npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:eval": "vitest run --project eval",
    "test:eval:smoke": "vitest run --project eval packages/evals/test/harness/workflow-authoring.eval.test.ts packages/evals/test/harness/intent-classification.eval.test.ts packages/evals/test/harness/workflow-authoring-demo.test.ts packages/evals/test/harness/intent-classification-demo.test.ts packages/evals/test/harness/eval-matrix-count.test.ts packages/evals/test/fixtures/load-eval-cases.test.ts",
    "test:eval:matrix": "vitest run --project eval packages/evals/test/harness/matrix-workflow-create.eval.test.ts packages/evals/test/harness/matrix-workflow-patch.eval.test.ts packages/evals/test/harness/matrix-intent.eval.test.ts packages/evals/test/harness/matrix-assistant.eval.test.ts packages/evals/test/harness/eval-matrix-count.test.ts packages/evals/test/harness/matrix-descriptor-order.eval.test.ts packages/evals/test/fixtures/load-eval-cases.test.ts",
    "eval:harness": "npm run test:eval",
    "eval:matrix": "npm run test:eval:matrix",
    "test:eval:matrix:coding": "vitest run --project eval packages/evals/test/harness/matrix-workflow-create-coding.eval.test.ts packages/evals/test/harness/matrix-workflow-patch-coding.eval.test.ts packages/evals/test/harness/matrix-intent-coding.eval.test.ts packages/evals/test/harness/matrix-assistant-coding.eval.test.ts packages/evals/test/harness/eval-matrix-count.test.ts packages/evals/test/fixtures/load-eval-cases.test.ts",
    "eval:matrix:coding": "npm run test:eval:matrix:coding",
    "eval:matrix:chrome": "vitest run --project eval-browser",
    "eval:matrix:chrome:smoke": "vitest run --project eval-browser packages/evals/test/browser/matrix-workflow-patch.eval.test.ts packages/evals/test/browser/matrix-intent.eval.test.ts packages/evals/test/browser/matrix-descriptor-order.eval.test.ts",
    "eval": "npm run eval:harness",
    "test:browser:install": "playwright install chromium --with-deps",
    "test:browser": "vitest run --project browser",
    "test:browser:watch": "vitest --project browser",
    "dev:browser-demo": "npm run dev -w @ecp/browser-demo",
    "build:browser-demo": "npm run build -w @ecp/browser-demo",
    "build:browser-demo:pages": "npm run build:pages -w @ecp/browser-demo",
    "typecheck:browser-demo": "npm run typecheck -w @ecp/browser-demo",
    "check": "npm run build && npm run generate:schema && npm run lint && npm run build:browser-demo && npm run test:unit && npm run test:integration && npm run test:e2e",
    "generate:schema": "npm run generate:schema -w @ecp/types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.49.0",
    "eslint": "^9.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
