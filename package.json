{
  "name": "@ecp/workspace",
  "version": "1.0.0",
  "description": "Execution Control Protocol (ECP) — TypeScript fluent API for workflow authoring and execution",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/types",
    "packages/core",
    "packages/mcp",
    "packages/cli",
    "packages/policies",
    "packages/extensions/*",
    "packages/runtimes/*"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "tsc -b tsconfig.build.json",
    "lint": "eslint . && markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#packages/*/node_modules\"",
    "lint:ts": "eslint .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#packages/*/node_modules\"",
    "test": "npm run build && npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "check": "npm run build && npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
